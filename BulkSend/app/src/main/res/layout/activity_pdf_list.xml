<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    tools:context=".pdfviewer.PdfListActivity">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#EF4444">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PDF Viewer"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSelectPdf"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ Select PDF File"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@android:color/white"
            android:textColor="#EF4444" />

    </LinearLayout>

    <!-- Recent PDFs Section -->
    <LinearLayout
        android:id="@+id/layoutRecentSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent PDFs"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="12dp" />

    </LinearLayout>

    <!-- Recent PDFs ListView -->
    <ListView
        android:id="@+id/listViewRecentPdfs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E5E7EB"
        android:dividerHeight="1dp"
        android:visibility="gone" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_view"
            android:tint="#D1D5DB"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Recent PDFs"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#9CA3AF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open a PDF file to see it here"
            android:textSize="14sp"
            android:textColor="#D1D5DB"
            android:textAlignment="center" />

    </LinearLayout>

</LinearLayout>
